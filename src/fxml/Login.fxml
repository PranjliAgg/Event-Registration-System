<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.eventregistration.controller.LoginController"
           styleClass="root-pane">

    <VBox alignment="CENTER" spacing="20" styleClass="login-container">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8" styleClass="login-header">
            <Label text="&#x1F4C5; EventHub" styleClass="app-title"/>
            <Label text="Welcome Back" styleClass="login-title"/>
            <Label text="Sign in to your account" styleClass="login-subtitle"/>
        </VBox>

        <!-- Login Form Card -->
        <VBox spacing="0" styleClass="login-card-modern">
            <GridPane hgap="15" vgap="12" styleClass="login-form">
                <Label text="Email Address:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="emailField" promptText="you@college.edu" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="form-field" prefWidth="250"/>

                <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                <PasswordField fx:id="passwordField" promptText="••••••••" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="form-field"/>
            </GridPane>

            <VBox spacing="10" styleClass="form-actions">
                <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true"/>
                <Button fx:id="loginBtn" text="Sign In" onAction="#handleLogin" styleClass="btn-primary-modern"/>
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Don't have an account?" styleClass="hint-text"/>
                    <Hyperlink fx:id="registerLink" text="Register here" onAction="#handleRegisterLink" styleClass="link"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Demo Credentials -->
        <VBox spacing="5" styleClass="demo-section">
            <Label text="Demo Credentials:" styleClass="demo-title"/>
            <Label text="Admin: admin@college.edu / admin*123" styleClass="demo-text"/>
            <Label text="User: alice@student.edu / alice*123" styleClass="demo-text"/>
        </VBox>
    </VBox>
</StackPane>

