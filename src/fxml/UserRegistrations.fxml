<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eventregistration.controller.UserDashboardController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="16">
            <Label text="📅 EventHub - My Registrations" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" styleClass="nav-welcome"/>
            <Button text="Back" onAction="#handleBackToMain" styleClass="btn-outline"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox spacing="16" styleClass="tab-content">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="My Registrations" styleClass="section-heading"/>

                <VBox fx:id="userRegistrationsContainer" spacing="10" VBox.vgrow="ALWAYS"/>

                <Label fx:id="statusLabel" styleClass="status-label" visible="false"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
